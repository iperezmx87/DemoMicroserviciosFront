@page "/login"
@inject BankApiService ApiService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Iniciar Sesión - BancoApp</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="d-flex align-center justify-center" Style="height: 100vh;">
    <MudCard Elevation="8" Class="pa-6 rounded-lg border-gradient" Style="width: 100%; background: #161b22; border: 1px solid #21262d;">
        <MudCardContent>
            <div class="d-flex flex-column align-center mb-6">
                <div class="d-flex align-center justify-center rounded-circle mb-3" 
                     Style="background: rgba(56, 189, 248, 0.1); width: 64px; height: 64px; border: 1px solid rgba(56, 189, 248, 0.2);">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Primary" Size="Size.Large" />
                </div>
                <MudText Typo="Typo.h5" Align="Align.Center" Style="font-weight: 700; color: #f0f6fc;">
                    Iniciar Sesión
                </MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary" Style="color: #8b949e;">
                    Portal Bancario Blazor
                </MudText>
            </div>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4 rounded-lg" Elevation="2">
                    @_errorMessage
                </MudAlert>
            }

            <EditForm Model="@_loginModel" OnValidSubmit="HandleLoginAsync">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="_loginModel.Usuario" 
                              Label="Usuario o Correo" 
                              Variant="Variant.Outlined" 
                              Margin="Margin.Normal"
                              FullWidth="true"
                              Disabled="_isLoading"
                              Class="mb-3" />

                <MudTextField @bind-Value="_loginModel.Secreto" 
                              Label="Contraseña" 
                              InputType="InputType.Password"
                              Variant="Variant.Outlined" 
                              Margin="Margin.Normal"
                              FullWidth="true"
                              Disabled="_isLoading"
                              Class="mb-6" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Class="py-3 rounded-lg font-weight-bold"
                           Style="text-transform: none; font-size: 1.1rem; box-shadow: 0 4px 12px rgba(56, 189, 248, 0.2);"
                           Disabled="_isLoading">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Color="Color.Default" Class="mr-2" />
                        <span>Autenticando...</span>
                    }
                    else
                    {
                        <span>Acceder</span>
                    }
                </MudButton>
            </EditForm>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private LoginModel _loginModel = new();
    private bool _isLoading;
    private string _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        // Si el usuario ya está autenticado, redirigir directamente al dashboard
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity != null && user.Identity.IsAuthenticated)
        {
            NavigationManager.NavigateTo("dashboard");
        }
    }

    private async Task HandleLoginAsync()
    {
        if (string.IsNullOrWhiteSpace(_loginModel.Usuario) || string.IsNullOrWhiteSpace(_loginModel.Secreto))
        {
            _errorMessage = "Por favor, ingresa tu usuario y contraseña.";
            return;
        }

        _isLoading = true;
        _errorMessage = null;

        try
        {
            var result = await ApiService.LoginAsync(_loginModel.Usuario, _loginModel.Secreto);

            if (result.Success && !string.IsNullOrWhiteSpace(result.Token))
            {
                var customProvider = (CustomAuthenticationStateProvider)AuthStateProvider;
                await customProvider.MarkUserAsAuthenticatedAsync(result.Token);
                
                Snackbar.Add("¡Sesión iniciada correctamente!", Severity.Success);
                NavigationManager.NavigateTo("dashboard");
            }
            else
            {
                _errorMessage = result.Mensaje ?? "Credenciales incorrectas.";
            }
        }
        catch (Exception)
        {
            _errorMessage = "Error de conexión con el servidor. Verifica que los servicios estén encendidos.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    public class LoginModel
    {
        public string Usuario { get; set; }
        public string Secreto { get; set; }
    }
}

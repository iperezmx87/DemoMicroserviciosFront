@page "/dashboard"
@attribute [Authorize]
@inject BankApiService ApiService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Dashboard - BancoApp</PageTitle>

<MudLayout Style="min-height: 100vh; background: #0d1117;">
    <!-- AppBar Premium -->
    <MudAppBar Elevation="2" Style="background: #161b22; border-bottom: 1px solid #21262d;">
        <MudText Typo="Typo.h6" Class="font-weight-bold ml-3" Color="Color.Primary" Style="font-size: 1.3rem; letter-spacing: 0.5px;">
            BancoApp
        </MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Text" 
                   Color="Color.Inherit" 
                   OnClick="HandleLogoutAsync" 
                   EndIcon="@Icons.Material.Filled.Logout"
                   Style="text-transform: none; color: #8b949e;"
                   Class="hover-opacity">
            Cerrar Sesión
        </MudButton>
    </MudAppBar>

    <MudMainContent Class="pt-16">
        <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8 px-4">
            <!-- Saludo -->
            <div class="mb-8">
                <MudText Typo="Typo.h3" Class="font-weight-bold mb-2" Style="color: #f0f6fc;">
                    Hola, @_propietario
                </MudText>
                <MudText Typo="Typo.subtitle1" Style="color: #8b949e;">
                    Aquí tienes el resumen de tu cuenta bancaria.
                </MudText>
            </div>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-6 rounded-lg" Elevation="2">
                    @_errorMessage
                </MudAlert>
            }

            <!-- Tarjeta de Saldo Principal -->
            <MudCard Elevation="4" Class="pa-6 rounded-lg mb-8" Style="background: #161b22; border: 1px solid #21262d;">
                <MudGrid Class="align-center justify-space-between" Spacing="4">
                    <MudItem xs="12" sm="7" Class="d-flex align-center">
                        <!-- Icono -->
                        <div class="d-flex align-center justify-center rounded-lg mr-4 pa-4" 
                             Style="background: rgba(56, 189, 248, 0.1); border: 1px solid rgba(56, 189, 248, 0.15);">
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Primary" Style="font-size: 3rem;" />
                        </div>
                        <!-- Info Saldo -->
                        <div>
                            <MudText Typo="Typo.overline" Style="color: #8b949e; letter-spacing: 1px;">
                                Saldo Actual
                            </MudText>
                            @if (_isLoading)
                            {
                                <MudProgressCircular Size="Size.Small" Color="Color.Primary" Class="d-block mt-1" />
                            }
                            else
                            {
                                <MudText Typo="Typo.h3" Class="font-weight-bold" Style="color: #f0f6fc;">
                                    $@_saldoActual.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("es-MX"))
                                </MudText>
                            }
                        </div>
                    </MudItem>

                    <!-- Botones de Acción -->
                    <MudItem xs="12" sm="5" Class="d-flex gap-4 justify-end flex-wrap">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Send"
                                   OnClick="NavigateToTransfer"
                                   Disabled="_isLoading || !_cuentaId.HasValue"
                                   Class="px-5 py-3 rounded-lg font-weight-bold"
                                   Style="text-transform: none; font-size: 1rem; box-shadow: 0 4px 12px rgba(56, 189, 248, 0.2);">
                            Transferir
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.History"
                                   OnClick="NavigateToHistory"
                                   Disabled="_isLoading || !_cuentaId.HasValue"
                                   Class="px-5 py-3 rounded-lg font-weight-bold"
                                   Style="text-transform: none; font-size: 1rem; border-color: rgba(168, 85, 247, 0.4); color: #c084fc;">
                            Historial
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudCard>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _isLoading = true;
    private string _errorMessage;
    private string _propietario = "Usuario";
    private Guid? _cuentaId;
    private decimal _saldoActual = 0;
    private System.Threading.Timer _logoutTimer;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity == null || !user.Identity.IsAuthenticated)
        {
            NavigationManager.NavigateTo("login");
            return;
        }

        try
        {
            // Extraer claims
            _propietario = user.FindFirst("Propietario")?.Value ?? user.Identity.Name ?? "Usuario";
            var idCuentaStr = user.FindFirst("IdCuenta")?.Value;
            
            if (Guid.TryParse(idCuentaStr, out var parsedId))
            {
                _cuentaId = parsedId;
            }

            // Configurar el temporizador de cierre de sesión automático basado en la expiración del JWT
            var expClaim = user.FindFirst("exp")?.Value;
            if (expClaim != null && long.TryParse(expClaim, out var exp))
            {
                var currentTime = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
                var remainingSeconds = exp - currentTime;

                if (remainingSeconds > 0)
                {
                    _logoutTimer = new System.Threading.Timer(async _ =>
                    {
                        await InvokeAsync(async () =>
                        {
                            Snackbar.Add("Tu sesión ha expirado por seguridad.", Severity.Warning);
                            await HandleLogoutAsync();
                        });
                    }, null, TimeSpan.FromSeconds(remainingSeconds), System.Threading.Timeout.InfiniteTimeSpan);
                }
                else
                {
                    await HandleLogoutAsync();
                    return;
                }
            }

            if (_cuentaId.HasValue)
            {
                var customProvider = (CustomAuthenticationStateProvider)AuthStateProvider;
                var token = await customProvider.GetTokenAsync();
                
                if (!string.IsNullOrWhiteSpace(token))
                {
                    _saldoActual = await ApiService.GetSaldoAsync(_cuentaId.Value, token);
                }
                else
                {
                    _errorMessage = "No se pudo obtener el token de sesión.";
                }
            }
            else
            {
                _errorMessage = "Tu cuenta de usuario no tiene asignada una cuenta de ahorros.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "No se pudo cargar el saldo actual. Verifica que las APIs estén encendidas.";
            Console.WriteLine(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void NavigateToTransfer()
    {
        NavigationManager.NavigateTo("transferencia");
    }

    private void NavigateToHistory()
    {
        NavigationManager.NavigateTo("movimientos");
    }

    private async Task HandleLogoutAsync()
    {
        var customProvider = (CustomAuthenticationStateProvider)AuthStateProvider;
        await customProvider.MarkUserAsLoggedOutAsync();
        NavigationManager.NavigateTo("login");
    }

    public void Dispose()
    {
        _logoutTimer?.Dispose();
    }
}
